// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product{
  id                Int      @id @default(autoincrement())
  serialNumber      String   @unique
  productName       String
  purchaseDate      DateTime
  warrantyExpiry    DateTime
  isActive          Boolean  @default(true)
  warrantyPdfUrl    String?
  pdfUploadedAt     DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt 
  repairs           Repair[]
}


model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100) // Limit name length
  email     String   @unique @db.VarChar(255) // Unique + length constraint
  password  String   @db.VarChar(255) // Store hashed password, not plain text
  phone     String?  @db.VarChar(15) // Optional, length constraint
  role      Role     @default(USER) // Enum for role validation
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  isVerified       Boolean   @default(false)
  resetToken       String?   @db.VarChar(255)
  resetTokenExpiry DateTime?
}

enum Role {
  USER
  ADMIN
}


enum RepairStatus{
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}


model Repair {
  id                    Int            @id @default(autoincrement())
  issue                 String
  repairStatus          RepairStatus   @default(PENDING)
  estimatedCompletion   DateTime?
  technicianNotes       String?
  repairDate            DateTime       @default(now())
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  productId             Int
  product               Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
}

